project_name := "vibe-seeker-frontend"
image_tag := env("IMAGE_TAG", "latest")
container_cli := env("CONTAINER_CLI", "podman")

# List all available recipes
default:
    @just --list

# Start dev server
dev:
    npm run dev

# Build for production
build:
    npm run build

# Run unit tests
test:
    npx vitest run

# Run integration tests (requires playwright setup)
test-integration:
    @echo "No integration tests configured yet"

# Run all static analysis
check:
    npx tsc --noEmit
    npx eslint .

# Format code
fmt:
    npx prettier --write .

# Remove build artifacts
clean:
    rm -rf dist/ node_modules/.cache

# Build the container image
container-build:
    {{container_cli}} build -t {{project_name}}:{{image_tag}} -f Containerfile .

# Full CI pipeline
ci: check test test-integration build container-build

# Run everything: fmt, check, test, integration test, build, container build
all: fmt ci
