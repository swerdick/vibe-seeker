image_name := "vibe-seeker-frontend"

# Install dependencies
install:
    npm ci

# Start dev server
dev:
    npm run dev

# Run TypeScript type checking
typecheck:
    npx tsc --noEmit

# Run ESLint
lint:
    npm run lint

# Run unit tests (requires vitest, see 13-testing.md)
test:
    npx vitest run

# Build for production
build:
    npm run build

# Build the container image
container:
    podman build -t {{image_name}} -f Containerfile .

# Run all CI-equivalent checks locally
check: install typecheck lint build container

# Remove build artifacts
clean:
    rm -rf dist
