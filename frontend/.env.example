# Cloudflare Turnstile (for anonymous access captcha)
# Get keys from https://dash.cloudflare.com → Turnstile
# Test key (always passes): 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# OpenTelemetry (optional — disabled by default)
# Traces are relayed through the backend at /api/otlp/v1/traces.
# To view traces locally, run: docker compose --profile dev up jaeger
# Then open Jaeger UI at http://localhost:16686
VITE_OTEL_ENABLED=false
VITE_OTEL_SERVICE_NAME=vibe-seeker-web
VITE_OTEL_ENVIRONMENT=local
