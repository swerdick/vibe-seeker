FROM golang:1.26-bookworm as builder

WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -o vibe-seeker ./cmd/server/

FROM debian:bookworm-slim as release

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app

COPY --from=builder /app/vibe-seeker .

EXPOSE 8080

CMD ["./vibe-seeker"]
