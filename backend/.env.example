# Spotify API credentials (required)
SPOTIFY_CLIENT_ID=your-client-id-here
SPOTIFY_CLIENT_SECRET=your-client-secret-here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/api/auth/callback

# Ticketmaster API credentials (required)
TICKETMASTER_CONSUMER_KEY=your-consumer-key-here
TICKETMASTER_CONSUMER_SECRET=your-consumer-secret-here

# Last.fm API credentials
LASTFM_API_KEY=your-api-key-here
LASTFM_SHARED_SECRET=your-shared-secret-here

# Auth (required — generate a random string for production)
JWT_SECRET=change-me-to-a-random-secret

# Cloudflare Turnstile (for anonymous access captcha)
# Get keys from https://dash.cloudflare.com → Turnstile
# Test keys: secret=1x0000000000000000000000000000000AA (always passes)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Frontend URL for OAuth redirects
FRONTEND_URL=http://127.0.0.1:5173

# Postgres (matches backend/compose.yml defaults)
DATABASE_URL=postgres://vibe_seeker:vibe_seeker@localhost:5432/vibe_seeker?sslmode=disable

# Backend configuration (optional — defaults shown)
OTEL_ENABLED=false
ENVIRONMENT=local
LOG_LEVEL=info
PORT=8080
APP_NAME=vibe-seeker-api
CORS_ORIGIN=http://localhost:5173
