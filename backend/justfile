set dotenv-load

project_name := "vibe-seeker-api"
image_tag := env("IMAGE_TAG", "latest")
container_cli := env("CONTAINER_CLI", "podman")

# List all available recipes
default:
    @just --list

# Run the server locally
dev:
    go run .

# Build the binary
build:
    CGO_ENABLED=0 go build -o bin/{{project_name}} .

# Run unit tests
test:
    go test ./... -short

# Run integration tests
test-integration:
    go test ./... -run Integration

# Run all static analysis
check:
    go vet ./...
    golangci-lint run ./...

# Format code
fmt:
    gofmt -w .
    goimports -w .

# Remove build artifacts
clean:
    rm -rf bin/
    go clean

# Build the container image
container-build:
    {{container_cli}} build -t {{project_name}}:{{image_tag}} -f Containerfile .

# Full CI pipeline
ci: check test test-integration build container-build

# Run everything: fmt, check, test, integration test, build, container build
all: fmt ci
